{
  "name": "honeystone/context",
  "description": "Application context manager for Laravel.",
  "license": "MIT",
  "keywords": [
    "honeystone",
    "context",
    "laravel"
  ],
  "authors": [
    {
      "name": "George Palmer",
      "email": "george@honeystone.com",
      "role": "Developer"
    }
  ],
  "homepage": "https://honeystone.com",
  "require": {
    "php": "^8.2",
    "spatie/laravel-package-tools": "^1.16.4",
    "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "laradumps/laradumps-core": "^4.0.5",
    "nunomaduro/collision": "^8.0",
    "nunomaduro/larastan": "^3.9",
    "laravel/pint": "^1.21",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan-deprecation-rules": "^2.0",
    "phpstan/phpstan-phpunit": "^2.0",
    "phpunit/phpunit": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "Honeystone\\Context\\": "src"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Honeystone\\Context\\Tests\\": "tests",
      "Workbench\\App\\": "workbench/app/",
      "Workbench\\Database\\Factories\\": "workbench/database/factories/",
      "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
    }
  },
  "scripts": {
    "analyse": "vendor/bin/phpstan analyse",
    "test": "vendor/bin/pest",
    "test-coverage": "vendor/bin/pest --coverage",
    "post-autoload-dump": [
      "@clear",
      "@prepare"
    ],
    "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
    "prepare": "@php vendor/bin/testbench package:discover --ansi",
    "build": "@php vendor/bin/testbench workbench:build --ansi",
    "serve": [
      "Composer\\Config::disableProcessTimeout",
      "@build",
      "@php vendor/bin/testbench serve"
    ],
    "lint": [
      "@php vendor/bin/phpstan analyse"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "phpstan/extension-installer": true,
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "pestphp/pest-plugin": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Honeystone\\Context\\Providers\\ContextServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable"
}
